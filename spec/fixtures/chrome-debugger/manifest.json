{
  "name": "chrome-debugger-test",
  "version": "1.0",
  "browser_action": {
    "default_title": "Debugger Test"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "manifest_version": 2,
  "permissions": [
    "debugger",
    "tabs",
    "<all_urls>"
  ]
}
